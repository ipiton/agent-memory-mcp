# agent-memory-mcp solo local preset
# Copy to .env in your project root.
#
# Config file search order (each file fills in values not already set):
#   1. --config /path/to/file  (explicit, skips chain)
#   2. .env in the current directory
#   3. ~/.config/agent-memory-mcp/config.env  (XDG)
#   4. $(brew --prefix)/etc/agent-memory-mcp/config.env  (Homebrew)
#
# This preset keeps local state inside a single .agent-memory/ directory.

# Core Configuration
MCP_ROOT=.
MCP_ALLOW_DIRS=.
MCP_MAX_FILE_BYTES=2097152
MCP_MAX_SEARCH_RESULTS=200
MCP_MAX_DEPTH=3
MCP_STDIO_MODE=line

# HTTP Server Configuration (set MCP_HTTP_MODE=http to enable)
MCP_HTTP_MODE=stdio
MCP_HTTP_HOST=127.0.0.1
MCP_HTTP_PORT=18080
# Loopback-only bind is safe for solo local mode without auth.
# For shared/service deployments set MCP_HTTP_HOST=0.0.0.0 and a bearer token.
# MCP_HTTP_AUTH_TOKEN=replace-with-long-random-token
# Explicitly unsafe override for non-loopback binds without auth.
# MCP_HTTP_INSECURE_ALLOW_UNAUTHENTICATED=false

# Data Storage Paths (relative to MCP_ROOT or absolute)
MCP_DATA_PATH=.agent-memory
MCP_RAG_INDEX_PATH=.agent-memory/rag-index
MCP_MEMORY_DB_PATH=.agent-memory/memory-store/memories.db
MCP_LOG_PATH=.agent-memory/logs/mcp-diagnostics.log

# RAG & Memory Configuration
MCP_RAG_ENABLED=true
MCP_RAG_MAX_RESULTS=10
MCP_MEMORY_ENABLED=true

# Document Indexing Configuration
# Comma-separated directories and files to index for RAG search (relative to MCP_ROOT)
# Supports both directories (recursive .md scan) and individual files.
# Examples:
#   MCP_INDEX_DIRS=docs                                    — single directory
#   MCP_INDEX_DIRS=docs,wiki,notes                         — multiple directories
#   MCP_INDEX_DIRS=docs,CHANGELOG.md                       — directory + single file
#   MCP_INDEX_DIRS=docs,src/api,design/decisions           — project docs + ADRs
#   MCP_INDEX_DIRS=docs,README.md,CONTRIBUTING.md          — directory + specific files
#   MCP_INDEX_DIRS=docs,runbooks,postmortems               — operational Markdown knowledge
#   MCP_INDEX_DIRS=docs,helm,k8s,terraform,.github/workflows — source-aware infra and CI files
#   MCP_INDEX_DIRS=/absolute/path/to/knowledge             — absolute path also works
MCP_INDEX_DIRS=docs,README.md,CHANGELOG.md
# Optional excludes for RAG indexing (applies before file reads/embeddings)
# MCP_INDEX_EXCLUDE_DIRS=.git,.idea,.vscode,.agent-memory,node_modules,logs
# MCP_INDEX_EXCLUDE_GLOBS=docs/internal/*.md,runbooks/private/*.md
# Redact common secret-like content before indexing documents
MCP_REDACT_SECRETS=true
MCP_CHUNK_SIZE=2000
MCP_CHUNK_OVERLAP=200

# Auto-indexing (recommended off for solo local; run `agent-memory-mcp index` explicitly)
MCP_RAG_AUTO_INDEX=false
MCP_RAG_FILE_WATCHER=false
MCP_RAG_WATCH_INTERVAL=5m
MCP_RAG_DEBOUNCE=30s

# Background session tracking
# Successful MCP tool calls are grouped into an active session.
# Idle timeout or shutdown runs background close-session orchestration:
# raw summaries are always saved, low-risk changes can auto-apply, risky ones go to the review queue.
MCP_SESSION_TRACKING_ENABLED=true
MCP_SESSION_IDLE_TIMEOUT=10m
MCP_SESSION_CHECKPOINT_INTERVAL=30m
MCP_SESSION_MIN_EVENTS=2

# Embeddings Configuration (at least one provider required)
# Modes:
#   MCP_EMBEDDING_MODE=auto       - hosted providers allowed, fallback to Ollama
#   MCP_EMBEDDING_MODE=local-only - never call Jina/OpenAI, use Ollama only
MCP_EMBEDDING_MODE=auto
#
# Priority in auto mode: Jina AI -> OpenAI -> Ollama (automatic fallback)
#
# Option 1: Jina AI API (high quality, multilingual)
JINA_API_KEY=your-jina-api-key-here
#
# Option 2: OpenAI-compatible API (OpenAI, Together AI, Mistral, etc.)
# OPENAI_API_KEY=your-openai-api-key-here
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small
#
# Option 3: Ollama (local, free, requires bge-m3 model)
OLLAMA_BASE_URL=http://localhost:11434
#
# Embedding dimension (default: 1024, must match across all providers)
# Increase for higher accuracy with models that support it (e.g. 3072 for text-embedding-3-large)
# WARNING: Changing this requires re-indexing all data (run index_documents tool)
# MCP_EMBEDDING_DIMENSION=1024

# Knowledge Stewardship
# Automated knowledge maintenance: duplicate detection, conflict resolution, stale detection.
# Auto-enabled in HTTP mode with memory; set explicitly to override.
# Modes: off, manual (run via steward_run tool), scheduled, event_driven
# MCP_STEWARD_ENABLED=true
MCP_STEWARD_MODE=manual
MCP_STEWARD_SCHEDULE_INTERVAL=24h
MCP_STEWARD_DUPLICATE_THRESHOLD=0.85
MCP_STEWARD_STALE_DAYS=30
MCP_STEWARD_CANONICAL_MIN_CONFIDENCE=0.80

# Checkpoint hook deduplication (T45)
# Suppresses near-duplicate session-checkpoint records written by the Claude Code
# checkpoint / auto-capture hooks. Applies to the CLI wrapper only; programmatic
# store_memory is unaffected. Set MCP_CHECKPOINT_DEDUP_DISABLED=true to bypass.
MCP_CHECKPOINT_DEDUP_THRESHOLD=0.9
MCP_CHECKPOINT_DEDUP_WINDOW=10m
MCP_CHECKPOINT_DEDUP_MIN_CHARS=100
# MCP_CHECKPOINT_DEDUP_DISABLED=false

# Task-lifecycle archive sweep (T47)
# Colon-separated archive roots (like PATH). When set, the sweep-archive / end-task
# CLI and MCP tools mark working/procedural memories tied to archived task slugs as
# outdated, routing high-importance ones to the review queue.
# MCP_TASK_ARCHIVE_ROOTS=/Users/you/tasks/archive
# MCP_TASK_SLUG_PATTERN=^[a-z0-9-]+$

# Neural reranker (T44) — opt-in cross-encoder re-scoring of hybrid search results.
# Off by default; 5s timeout with graceful fallback to hybrid order on error.
# Requires JINA_API_KEY (already configured above for embeddings).
# MCP_RERANK_ENABLED=false
# MCP_RERANK_PROVIDER=jina
# JINA_RERANKER_MODEL=jina-reranker-v2-base-multilingual
# MCP_RERANK_TIMEOUT=5s
# MCP_RERANK_TOP_N=40

# Statistics & Monitoring
MCP_STATS_ENABLED=false
MCP_STATS_PATH=.agent-memory/logs/mcp-usage.jsonl
MCP_STATS_SAMPLE_RATE=1.0
