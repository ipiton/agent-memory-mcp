# Copy to .env.shared and adjust for your shared deployment.

# Host project root to mount read-only into the container.
# Default ../.. works when running compose from deploy/docker/.
MCP_PROJECT_ROOT=../..

# Required for shared HTTP mode.
MCP_HTTP_HOST=0.0.0.0
MCP_HTTP_AUTH_TOKEN=replace-with-long-random-token

# Optional indexing overrides.
MCP_INDEX_DIRS=docs,README.md,CHANGELOG.md
MCP_INDEX_EXCLUDE_DIRS=.git,.agent-memory,node_modules,logs
MCP_REDACT_SECRETS=true

# Embeddings: local-only with Ollama is the default shared recipe.
MCP_EMBEDDING_MODE=local-only
# MCP_EMBEDDING_TIMEOUT=5s
# MCP_EMBEDDING_MAX_RETRIES=1

# Optional hosted provider settings if you intentionally want them.
JINA_API_KEY=
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_EMBEDDING_MODEL=
